@using Harjoitus_4_1_1.Models
@model Order

<div class="modal fade" id="editOrderModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title">Edit order: <em>@Html.DisplayFor(model => model.OrderID)</em></h2>
            </div>
            <div class="modal-body">
                @using (Html.BeginForm("_ModalEdit", "Orders", FormMethod.Post, new { id = "editForm" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    @Html.HiddenFor(model => model.OrderID)

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.CustomerID, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.DropDownListFor(model => model.CustomerID, (SelectList)ViewBag.CustomerID, "-- Select customer --", new { @class = "form-control" })
                            @Html.ValidationMessageFor(model => model.CustomerID, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <script>
                        (() => {
                            const modal = document.getElementById("editOrderModal");
                            if (!modal) return;
                                                        
                            // Force selected values from the model
                            const customerId = '@(Model.CustomerID ?? "")';
                            const employeeId = '@(Model.EmployeeID?.ToString() ?? "")';
                            const shipVia = '@(Model.ShipVia?.ToString() ?? "")';

                            const customerDropdown = modal.querySelector("#CustomerID");
                            const employeeDropdown = modal.querySelector("#EmployeeID");
                            const shipViaDropdown = modal.querySelector("#ShipVia");

                            if (customerDropdown) customerDropdown.value = customerId;
                            if (employeeDropdown) employeeDropdown.value = employeeId;
                            if (shipViaDropdown) shipViaDropdown.value = shipVia;

                            // Prevent duplicate binding if the modal is reopened/reloaded.
                            if (customerDropdown.dataset.prefillBound === "true") return;
                            customerDropdown.dataset.prefillBound = "true";

                            const fields = {
                                shipName: modal.querySelector("#ShipName"),
                                shipAddress: modal.querySelector("#ShipAddress"),
                                shipCity: modal.querySelector("#ShipCity"),
                                shipRegion: modal.querySelector("#ShipRegion"),
                                shipPostalCode: modal.querySelector("#ShipPostalCode"),
                                shipCountry: modal.querySelector("#ShipCountry")
                            };

                            const clearFields = () => {
                                Object.values(fields).forEach(el => { if (el) el.value = ""; });
                            };

                            customerDropdown.addEventListener("change", async () => {
                                const selectedCustomer = customerDropdown.value;

                                if (!selectedCustomer) {
                                    clearFields();
                                    return;
                                }

                                const url = '@Url.Action("GetCustomerForOrder", "Customers")' +
                                            '?id=' + encodeURIComponent(selectedCustomer);

                                try {
                                    const response = await fetch(url, { method: "GET" });

                                    if (!response.ok) {
                                        clearFields();
                                        return;
                                    }

                                    const customerDetails = await response.json();

                                    fields.shipName.value = customerDetails.CompanyName || "";
                                    fields.shipAddress.value = customerDetails.Address || "";
                                    fields.shipCity.value = customerDetails.City || "";
                                    fields.shipRegion.value = customerDetails.Region || "";
                                    fields.shipPostalCode.value = customerDetails.PostalCode || "";
                                    fields.shipCountry.value = customerDetails.Country || "";
                                } catch (err) {
                                    clearFields();
                                }
                            });
                        })();
                        (() => {
                            const modalEl = document.getElementById("editOrderModal");
                            if (!modalEl) return;

                            const form = modalEl.querySelector("#editForm");
                            if (!form) return;

                            // Avoid double-binding when modal HTML is replaced
                            if (form.dataset.ajaxBound === "true") return;
                            form.dataset.ajaxBound = "true";

                            $(form).on("submit", function (e) {
                                e.preventDefault();

                                $.ajax({
                                    url: form.action,
                                    type: "POST",
                                    data: $(form).serialize(),
                                    dataType: "json" // expect JSON on success
                                })
                                    .done(function (json) {
                                        if (!json || json.ok !== true) return;

                                        // Find the row by the pencil button for this orderId
                                        const btn = document.querySelector(".getOrderId[data-order-id='" + json.orderId + "']");
                                        const row = btn ? btn.closest("tr") : null;

                                        if (row) {
                                            const setText = (selector, value) => {
                                                const el = row.querySelector(selector);
                                                if (el) el.textContent = value ?? "";
                                            };

                                            setText(".cell-customer", json.customerName);
                                            setText(".cell-employee", json.employeeName);

                                            setText(".cell-orderdate", json.orderDate);
                                            setText(".cell-requireddate", json.requiredDate);
                                            setText(".cell-shippeddate", json.shippedDate);

                                            setText(".cell-totalamount", json.totalAmount);
                                            setText(".cell-totaltax", json.totalTax);
                                            setText(".cell-vattotal", json.vatTotal);
                                            setText(".cell-freight", json.freight);
                                            setText(".cell-finalprice", json.finalPrice);

                                            setText(".cell-shipcountry", json.shipCountry);
                                            setText(".cell-shipvia", json.shipperName);
                                        }

                                        // Close modal
                                        bootstrap.Modal.getOrCreateInstance(modalEl).hide();
                                    })    
                                    .fail(function (xhr) {
                                        // Validation failure: server returned the partial view HTML
                                        const host = $("#orderEdit");
                                        host.empty();
                                        host.html(xhr.responseText);

                                        const newModalEl = document.getElementById("editOrderModal");
                                        const modal = bootstrap.Modal.getOrCreateInstance(newModalEl);
                                        modal.show();
                                    });
                            });
                        })();
                    </script>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.EmployeeID, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.DropDownListFor(model => model.EmployeeID, (SelectList)ViewBag.EmployeeID, "-- Select employee --", new { @class = "form-control" })
                            @Html.ValidationMessageFor(model => model.EmployeeID, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.OrderDate, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.OrderDate, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.OrderDate, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.RequiredDate, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.RequiredDate, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.RequiredDate, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.ShippedDate, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.ShippedDate, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ShippedDate, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.ShipVia, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.DropDownListFor(model => model.ShipVia, (SelectList)ViewBag.ShipVia, "-- Select shipper --", new { @class = "form-control" })
                            @Html.ValidationMessageFor(model => model.ShipVia, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.Freight, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.Freight, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.Freight, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.ShipName, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.ShipName, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ShipName, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.ShipAddress, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.ShipAddress, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ShipAddress, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.ShipCity, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.ShipCity, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ShipCity, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.ShipRegion, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.ShipRegion, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ShipRegion, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.ShipPostalCode, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.ShipPostalCode, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ShipPostalCode, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.ShipCountry, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.ShipCountry, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ShipCountry, "", new { @class = "text-danger" })
                        </div>
                    </div>
                }

            </div>
            <div class="modal-footer">
                <div class="offset-md-2 col-md-10">
                    <button type="submit" form="editForm" class="btn btn-primary me-1" data-bs-dismiss="modal">
                        <i class="bi bi-floppy me-1" aria-hidden="true"></i>
                        <span>Save Changes</span>
                    </button>
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x me-1" aria-hidden="true"></i>
                        <span>Cancel</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>