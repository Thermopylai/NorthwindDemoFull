@using Harjoitus_4_1_1.ViewModels
@model SuppliersViewModel

@{
    ViewBag.Title = "Edit Supplier Details";
    var returnUrl = Request.Url.PathAndQuery;
}

<h2>@ViewBag.Title</h2>
<h5>Supplier: <em>@Html.DisplayFor(model => model.Supplier.SupplierID)</em></h5>
<hr />

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.Hidden("returnUrl", Model.ReturnUrl)
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(model => model.Supplier.SupplierID)

    <div class="mb-3 row">
        @Html.LabelFor(model => model.Supplier.CompanyName, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.Supplier.CompanyName, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Supplier.CompanyName, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.Supplier.ContactName, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.Supplier.ContactName, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Supplier.ContactName, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.Supplier.ContactTitle, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.Supplier.ContactTitle, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Supplier.ContactTitle, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.Supplier.Address, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.Supplier.Address, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Supplier.Address, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.Supplier.City, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.Supplier.City, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Supplier.City, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.Supplier.Region, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.Supplier.Region, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Supplier.Region, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.Supplier.PostalCode, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.Supplier.PostalCode, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Supplier.PostalCode, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.Supplier.Country, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.Supplier.Country, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Supplier.Country, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.Supplier.Phone, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.Supplier.Phone, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Supplier.Phone, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.Supplier.Fax, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.Supplier.Fax, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Supplier.Fax, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.Supplier.HomePage, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.Supplier.HomePage, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Supplier.HomePage, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="row">
        <div class="offset-md-2 col-md-10">
            <button type="submit" class="btn btn-primary me-1">
                <i class="bi bi-floppy me-1" aria-hidden="true"></i>
                <span>Save Changes</span>
            </button>
            <a href="@Model.ReturnUrl" class="btn btn-secondary">
                <i class="bi bi-skip-backward me-1" aria-hidden="true"></i>
                <span>Back</span>
            </a>
        </div>
    </div>
}

<div>
    <hr />

    <h5>Products associated with this supplier: @Model.ProductsCount</h5>

    @if (Model.ProductsCount == 0)
    {
        <p>No items found.</p>
    }
    else
    {
        <div class="table-search-container">
            <input type="text"
                   id="search-products"
                   onkeyup="filterTable('search-products', 'products-table')"
                   placeholder="Search..."
                   class="form-control mb-2">
        </div>

        <div class="table-wrapper">
            <table class="table table-striped table-bordered table-fixed" id="products-table">
                <colgroup>
                    <col style="width: 80px;" />   @* ProductID *@
                    <col style="width: 280px;" />  @* ProductName *@
                    <col style="width: 140px;" />  @* CategoryName *@
                    <col style="width: 180px;" />  @* QuantityPerUnit *@
                    <col style="width: 100px;" />  @* UnitPrice *@
                    <col style="width: 100px;" />  @* TaxAmount *@
                    <col style="width: 100px;" />  @* PriceWithTax *@
                    <col style="width: 300px;" />  @* Functions *@
                </colgroup>
                <thead class="table-dark">
                    <tr>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1"></i>@Html.DisplayNameFor(model => model.Products[0].ProductID)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Products[0].ProductName)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Products[0].Category.CategoryName)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Products[0].QuantityPerUnit)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Products[0].UnitPrice)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Products[0].TaxAmount)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Products[0].PriceWithTax)
                        </th>
                        <th class="text-nowrap">
                            Functions
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Products)
                    {
                        <tr>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].ProductID)">
                                @Html.DisplayFor(_ => item.ProductID)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].ProductName)">
                                @Html.DisplayFor(_ => item.ProductName)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].Category.CategoryName)">
                                @Html.DisplayFor(_ => item.Category.CategoryName)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].QuantityPerUnit)">
                                @Html.DisplayFor(_ => item.QuantityPerUnit)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].UnitPrice)">
                                @Html.DisplayFor(_ => item.UnitPrice)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].TaxAmount)">
                                @Html.DisplayFor(_ => item.TaxAmount)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].PriceWithTax)">
                                @Html.DisplayFor(_ => item.PriceWithTax)
                            </td>
                            <td class="cell-actions">
                                <a class="btn btn-sm btn-warning me-1" href="@Url.Action("Edit", "Products", new { id = item.ProductID, returnUrl = returnUrl })">
                                    <i class="bi bi-pencil-square me-1" aria-hidden="true"></i>
                                    <span>Edit</span>
                                </a>
                                <a class="btn btn-sm btn-info me-1" href="@Url.Action("Details", "Products", new { id = item.ProductID, returnUrl = returnUrl })">
                                    <i class="bi bi-info-square me-1" aria-hidden="true"></i>
                                    <span>Details</span>
                                </a>
                                @using (Html.BeginForm("MoveToRecycleBin", "Products",
                                    new { id = item.ProductID, returnUrl = returnUrl }, FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash-fill me-1" aria-hidden="true"></i>
                                        <span>Recycle</span>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                    <tr id="no-results-products" style="display: none; border: none">
                        <td colspan="2" style="text-align: center; padding: 40px; padding-left: 40px !important; color: #666; border: 1px solid; border-radius: 8px;">
                            No search results.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>

        @section Scripts {
            @Scripts.Render("~/bundles/jqueryval")
        }
