@model byte[]
@if (Model != null && Model.Length > 0)
{
    using (var ms = new MemoryStream())
    {
        // JPEG header offset
        int offset = 78;
        // Skip the first 78 bytes
        ms.Write(Model, offset, Model.Length - offset);
        // Get the byte array without the header
        var byteArray = ms.ToArray();
        // Convert to base64 string and create data URI
        var imgSrc = "data:image/jpeg;base64," + Convert.ToBase64String(byteArray);
        // Render the image
        <img src="@imgSrc" alt="Photo" />
    }
}
else
{
    <span>No photo available</span>
}
