@{ 
    var returnUrl = Request.Url.PathAndQuery;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Northwind-testi</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <script src="~/Scripts/theme-toggler.js"></script>
    <script src="~/Scripts/update-clock.js"></script>
    <script src="~/Scripts/sorter.js"></script>
    <script src="~/Scripts/search.js"></script>
    <script src="~/Scripts/horizontal-scrollbar.js"></script>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark">
        <div class="container">
            @if (Session["UserName"] == null)
            {
                <i class="bi-lock me-1"></i>
                @Html.ActionLink("Northwind", "Login", "Logins", new { area = "", returnUrl = returnUrl }, new { @class = "navbar-brand" })
            }
            else
            {
                <i class="bi-unlock me-1"></i>
                @Html.ActionLink("Northwind", "Logout", "Logins", new { area = "", returnUrl = returnUrl }, new { @class = "navbar-brand" })
            }
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Toggle navigation" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item dropdown">
                        <button class="btn btn-link nav-link dropdown-toggle d-flex align-items-center"
                                id="navbarDropdown"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            Menu
                        </button>
                        <ul class="dropdown-menu"
                            aria-labelledby="navbarDropdown">

                            <li>
                                @Html.ActionLink("Employees", "Index", "Employees",
                               new { area = "", returnUrl = @ViewBag.ReturnUrl },
                               new { @class = "dropdown-item" })
                            </li>

                            <li>
                                @Html.ActionLink("Customers", "Index", "Customers",
                               new { area = "", returnUrl = @ViewBag.ReturnUrl },
                               new { @class = "dropdown-item" })
                            </li>

                            <li>
                                @Html.ActionLink("Demographics", "Index", "CustomerDemographics",
                               new { area = "", returnUrl = @ViewBag.ReturnUrl },
                               new { @class = "dropdown-item" })
                            </li>

                            <li>
                                @Html.ActionLink("Orders", "Index", "Orders",
                               new { area = "", returnUrl = @ViewBag.ReturnUrl },
                               new { @class = "dropdown-item" })
                            </li>

                            <li>
                                @Html.ActionLink("Items", "Index", "Order_Detail",
                               new { area = "", returnUrl = @ViewBag.ReturnUrl },
                               new { @class = "dropdown-item" })
                            </li>

                            <li>
                                @Html.ActionLink("Categories", "Index", "Categories",
                                new { area = "", returnUrl = @ViewBag.ReturnUrl },
                                new { @class = "dropdown-item" })
                            </li>

                            <li>
                                @Html.ActionLink("Products", "Index", "Products",
                               new { area = "", returnUrl = @ViewBag.ReturnUrl },
                               new { @class = "dropdown-item" })
                            </li>

                            <li>
                                @Html.ActionLink("Suppliers", "Index", "Suppliers",
                               new { area = "", returnUrl = @ViewBag.ReturnUrl },
                               new { @class = "dropdown-item" })
                            </li>

                            <li>
                                @Html.ActionLink("Regions", "Index", "Regions",
                               new { area = "", returnUrl = @ViewBag.ReturnUrl },
                               new { @class = "dropdown-item" })
                            </li>

                            <li>
                                @Html.ActionLink("Territories", "Index", "Territories",
                               new { area = "", returnUrl = @ViewBag.ReturnUrl },
                               new { @class = "dropdown-item" })
                            </li>

                            <li>
                                @Html.ActionLink("Shippers", "Index", "Shippers",
                               new { area = "", returnUrl = @ViewBag.ReturnUrl },
                               new { @class = "dropdown-item" })
                            </li>

                        </ul>
                    </li>
                    <li class="nav-link"><span id="clock"></span></li>
                    <li class="nav-item dropdown">
                        <button class="btn btn-link nav-link dropdown-toggle d-flex align-items-center"
                                id="bd-theme"
                                type="button"
                                data-bs-toggle="dropdown"
                                data-bs-display="static"
                                aria-expanded="false"
                                aria-label="Toggle theme (auto)">
                            <i class="bi-circle-half my-1"
                               id="theme-icon-active"
                               aria-hidden="true"></i>
                            <span id="bd-theme-text" class="d-none">Toggle theme</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-start"
                            aria-labelledby="bd-theme-text">
                            <li>
                                <button type="button"
                                        class="dropdown-item d-flex align-items-center"
                                        data-bs-theme-value="light"
                                        aria-pressed="false">
                                    <i class="bi-sun-fill me-2 opacity-50"
                                       id="theme-icon"
                                       aria-hidden="true"></i>
                                    Light
                                    <i class="bi-check2 ms-auto d-none"
                                       id="is-checked"
                                       aria-hidden="true"></i>
                                </button>
                            </li>
                            <li>
                                <button type="button"
                                        class="dropdown-item d-flex align-items-center"
                                        data-bs-theme-value="dark"
                                        aria-pressed="false">
                                    <i class="bi-moon-stars-fill me-2 opacity-50"
                                       id="theme-icon"
                                       aria-hidden="true"></i>
                                    Dark
                                    <i class="bi-check2 ms-auto d-none"
                                       id="is-checked"
                                       aria-hidden="true"></i>
                                </button>
                            </li>
                            <li>
                                <button type="button"
                                        class="dropdown-item d-flex align-items-center active"
                                        data-bs-theme-value="auto"
                                        aria-pressed="true">
                                    <i class="bi-circle-half me-2 opacity-50"
                                       id="theme-icon"
                                       aria-hidden="true"></i>
                                    Auto
                                    <i class="bi-check2 ms-auto"
                                       id="is-checked"
                                       aria-hidden="true"></i>
                                </button>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - Northwind-testi</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/popper")
    @Scripts.Render("~/bundles/bootstrap")
    <script src="~/Scripts/currency-input.js"></script>
    <script src="~/Scripts/discount-input.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
