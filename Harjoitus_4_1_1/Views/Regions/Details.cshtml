                                @Html.DisplayFor(_ => item.Phone)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Shippers[0].RegionID)">
                                @Html.DisplayFor(_ => item.Region.RegionDescription)
                            </td>
                            <td class="cell-actions">
                                <a class="btn btn-sm btn-warning me-1" href="@Url.Action("Edit", "Shippers", new { id = item.ShipperID, returnUrl = returnToThisUrl })">
