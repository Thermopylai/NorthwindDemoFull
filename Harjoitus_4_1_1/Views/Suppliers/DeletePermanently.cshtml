@using Harjoitus_4_1_1.ViewModels
@model SuppliersViewModel

@{
    ViewBag.Title = "Delete Supplier Permanently";
    var returnUrl = Request.Url.PathAndQuery;
}

<h2>@ViewBag.Title</h2>
<h4>Are you sure you want to delete this permanently?</h4>
<h5>Supplier: <em>@Html.DisplayFor(model => model.Supplier.SupplierID)</em></h5>
<h6>@Html.ValidationSummary(true, "", new { @class = "text-danger" })</h6>
<hr />

<div class="mt-3">
    <dl class="row">

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Supplier.CompanyName)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Supplier.CompanyName)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Supplier.ContactName)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Supplier.ContactName)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Supplier.ContactTitle)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Supplier.ContactTitle)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Supplier.Address)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Supplier.Address)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Supplier.City)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Supplier.City)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Supplier.Region)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Supplier.Region)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Supplier.PostalCode)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Supplier.PostalCode)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Supplier.Country)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Supplier.Country)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Supplier.Phone)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Supplier.Phone)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Supplier.Fax)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Supplier.Fax)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Supplier.HomePage)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Supplier.HomePage)
        </dd>

    </dl>

    @using (Html.BeginForm("DeletePermanently", "Suppliers", new { id = Model.Supplier.SupplierID, returnUrl = Model.ReturnUrl }, FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <div class="mt-3 offset-md-2 col-md-10">
            <button type="submit" class="btn btn-danger me-1">
                <i class="bi bi-trash me-1" aria-hidden="true"></i>
                <span>Delete</span>
            </button>
            <a href="@Model.ReturnUrl" class="btn btn-secondary">
                <i class="bi bi-skip-backward me-1" aria-hidden="true"></i>
                <span>Back</span>
            </a>
        </div>
    }
</div>

<div>
    <hr />

    <h5>Products associated with this supplier: @Model.ProductsCount</h5>

    @if (Model.ProductsCount == 0)
    {
        <p>No items found.</p>
    }
    else
    {
        <h6><strong>Warning!</strong> This supplier has associated products. Remove or reassign these first!</h6>

        <div class="table-search-container">
            <input type="text"
                   id="search-products"
                   onkeyup="filterTable('search-products', 'products-table')"
                   placeholder="Search..."
                   class="form-control mb-2">
        </div>

        <div class="table-wrapper">
            <table class="table table-striped table-bordered table-fixed" id="products-table">
                <colgroup>
                    <col style="width: 80px;" />   @* ProductID *@
                    <col style="width: 280px;" />  @* ProductName *@
                    <col style="width: 140px;" />  @* CategoryName *@
                    <col style="width: 180px;" />  @* QuantityPerUnit *@
                    <col style="width: 100px;" />  @* UnitPrice *@
                    <col style="width: 100px;" />  @* TaxAmount *@
                    <col style="width: 100px;" />  @* PriceWithTax *@
                    <col style="width: 80px;" />   @* Discontinued *@
                    <col style="width: 300px;" />  @* Functions *@
                </colgroup>
                <thead class="table-dark">
                    <tr>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1"></i>@Html.DisplayNameFor(model => model.Products[0].ProductID)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Products[0].ProductName)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Products[0].Category.CategoryName)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Products[0].QuantityPerUnit)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Products[0].UnitPrice)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Products[0].TaxAmount)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Products[0].PriceWithTax)
                        </th>
                        <th class="text-nowrap">
                            @Html.DisplayNameFor(model => model.Products[0].Discontinued)
                        </th>
                        <th class="text-nowrap">
                            Functions
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Products)
                    {
                        <tr>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].ProductID)">
                                @Html.DisplayFor(_ => item.ProductID)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].ProductName)">
                                @Html.DisplayFor(_ => item.ProductName)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].Category.CategoryName)">
                                @Html.DisplayFor(_ => item.Category.CategoryName)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].QuantityPerUnit)">
                                @Html.DisplayFor(_ => item.QuantityPerUnit)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].UnitPrice)">
                                @Html.DisplayFor(_ => item.UnitPrice)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].TaxAmount)">
                                @Html.DisplayFor(_ => item.TaxAmount)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].PriceWithTax)">
                                @Html.DisplayFor(_ => item.PriceWithTax)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Products[0].Discontinued)">
                                @Html.DisplayFor(_ => item.Discontinued)
                            </td>
                            <td class="cell-actions">
                                <a class="btn btn-sm btn-warning me-1" href="@Url.Action("Edit", "Products", new { id = item.ProductID, returnUrl = returnUrl })">
                                    <i class="bi bi-pencil-square me-1" aria-hidden="true"></i>
                                    <span>Edit</span>
                                </a>
                                <a class="btn btn-sm btn-info me-1" href="@Url.Action("Details", "Products", new { id = item.ProductID, returnUrl = returnUrl })">
                                    <i class="bi bi-info-square me-1" aria-hidden="true"></i>
                                    <span>Details</span>
                                </a>
                                <a class="btn btn-sm btn-danger" href="@Url.Action("DeletePermanently", "Products", new { id = item.ProductID, returnUrl = returnUrl })">
                                    <i class="bi bi-trash me-1" aria-hidden="true"></i>
                                    <span>Delete</span>
                                </a>
                            </td>
                        </tr>
                    }
                    <tr id="no-results-products" style="display: none; border: none">
                        <td colspan="2" style="text-align: center; padding: 40px; padding-left: 40px !important; color: #666; border: 1px solid; border-radius: 8px;">
                            No search results.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>