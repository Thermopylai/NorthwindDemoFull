@using Harjoitus_4_1_1.Models
@model IEnumerable<Category>

@{
    ViewBag.Title = "Categories";
    var returnUrl = (string)ViewBag.ReturnUrl ?? Request.Url.PathAndQuery;
}

<h2>@ViewBag.Title</h2>
<hr />

<div class="d-flex flex-wrap align-items-center gap-2 mb-2">
    <a class="btn btn-primary me-1" href="@Url.Action("Create", new { returnUrl = returnUrl })">
        <i class="bi bi-file-earmark-plus me-1" aria-hidden="true"></i>
        <span>Create New</span>
    </a>
    <a class="btn btn-outline-secondary me-1" href="@Url.Action("RecycleBin", new { returnUrl = returnUrl })">
        <i class="bi bi-trash-fill me-1" aria-hidden="true"></i>
        <span>Recycle Bin</span>
    </a>
    <input type="text"
           id="search-categories"
           onkeyup="filterTable('search-categories', 'categories-table')"
           placeholder="Search..."
           class="form-control">
</div>

<div class="table-wrapper">
    <table class="table table-striped table-bordered table-fixed" id="categories-table">
        <colgroup>
            <col style="width: 50px;" />   @* CategoryID *@
            <col style="width: 100px;" />  @* CategoryName *@
            <col style="width: 60px;" />   @* ProductsInCategoryCount *@
            <col style="width: 100px;" />  @* Description *@
            <col style="width: 100px;" />  @* Picture *@
            <col style="width: 150px;" />  @* Functions *@
        </colgroup>
        <thead class="table-dark">
            <tr>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1"></i>@Html.DisplayNameFor(model => model.CategoryID)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.CategoryName)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.ProductsInCategoryCount)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Description)
                </th>
                <th class="text-nowrap">
                    @Html.DisplayNameFor(model => model.Picture)
                </th>
                <th class="text-nowrap">
                    Functions
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td data-label="@Html.DisplayNameFor(model => model.CategoryID)">
                        @Html.DisplayFor(_ => item.CategoryID)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.CategoryName)">
                        @Html.DisplayFor(_ => item.CategoryName)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.ProductsInCategoryCount)">
                        @Html.DisplayFor(_ => item.ProductsInCategoryCount)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.Description)">
                        @Html.DisplayFor(_ => item.Description)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.Picture)">
                        @Html.DisplayFor(_ => item.Picture)
                    </td>
                    <td class="cell-actions">
                        <a class="btn btn-sm btn-warning me-1" href="@Url.Action("Edit", new { id = item.CategoryID, returnUrl = returnUrl })">
                            <i class="bi bi-pencil-square me-1" aria-hidden="true"></i>
                            <span>Edit</span>
                        </a>
                        <a class="btn btn-sm btn-info me-1" href="@Url.Action("Details", new { id = item.CategoryID, returnUrl = returnUrl })">
                            <i class="bi bi-info-square me-1" aria-hidden="true"></i>
                            <span>Details</span>
                        </a>
                        @using (Html.BeginForm("MoveToRecycleBin", "Categories",
                            new { id = item.CategoryID, returnUrl = returnUrl }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash-fill me-1" aria-hidden="true"></i>
                                <span>Recycle</span>
                            </button>
                        }
                    </td>
                </tr>
            }
            <tr id="no-results-categories" style="display: none; border: none">
                <td colspan="2" style="text-align: center; padding: 40px; padding-left: 40px !important; color: #666; border: 1px solid; border-radius: 8px;">
                    No search results.
                </td>
            </tr>
        </tbody>
    </table>
</div>
