@using Harjoitus_4_1_1.Models
@model IEnumerable<Order>

@{
    ViewBag.Title = "Orders";
    var returnUrl = (string)ViewBag.ReturnUrl ?? Request.Url.PathAndQuery;
}

<h2>@ViewBag.Title</h2>
<hr />

<div class="d-flex flex-wrap align-items-center gap-2 mb-2">
    <a class="btn btn-primary me-1" href="@Url.Action("Create", new { returnUrl = returnUrl })">
        <i class="bi bi-file-earmark-plus me-1" aria-hidden="true"></i>
        <span>Create New</span>
    </a>
    <a class="btn btn-outline-secondary me-1" href="@Url.Action("RecycleBin", new { returnUrl = returnUrl })">
        <i class="bi bi-trash-fill me-1" aria-hidden="true"></i>
        <span>Recycle Bin</span>
    </a>
    <input type="text"
           id="search-orders"
           onkeyup="filterTable('search-orders', 'orders-table')"
           placeholder="Search..."
           class="form-control">
    @using (Html.BeginForm("Index", "Orders", FormMethod.Get, new { @class = "d-flex align-items-center gap-2" }))
    {
        <span class="text-nowrap">Select Country:</span>
        @Html.DropDownList("shipCountry", (SelectList)ViewBag.ShipCountry, "All", htmlAttributes: new { @class = "form-control" })

        <span class="text-nowrap">Select Customer:</span>
        @Html.DropDownList("customerId", (SelectList)ViewBag.CustomerID, "All", htmlAttributes: new { @class = "form-control" })

        <span class="text-nowrap">Select Shipper:</span>
        @Html.DropDownList("shipVia", (SelectList)ViewBag.ShipVia, "All", htmlAttributes: new { @class = "form-control" })

        <input type="submit" value="Filter" class="btn btn-outline-primary" />
    }
</div>

<div id="orderEdit"></div>

<div class="table-wrapper">
    <table class="table table-striped table-bordered table-fixed" id="orders-table">
        <colgroup>
            <col style="width: 45px;" />   @* Edit button *@
            <col style="width: 80px;" />   @* OrderID *@
            <col style="width: 260px;" />  @* Customer *@
            <col style="width: 100px;" />  @* Employee *@
            <col style="width: 100px;" />  @* OrderDate *@
            <col style="width: 100px;" />  @* RequiredDate *@
            <col style="width: 100px;" />  @* ShippedDate *@
            <col style="width: 100px;" />  @* TotalAmount *@
            <col style="width: 100px;" />  @* TotalTax *@
            <col style="width: 100px;" />  @* VatTotal *@
            <col style="width: 100px;" />  @* Freight *@
            <col style="width: 100px;" />  @* FinalPrice *@
            <col style="width: 110px;" />  @* ShipCountry *@
            <col style="width: 150px;" />  @* Shipper *@
            <col style="width: 300px;" />  @* Functions *@
        </colgroup>

        <thead class="table-dark">
            <tr>
                <th></th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1"></i>@Html.DisplayNameFor(model => model.OrderID)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.CustomerID)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.EmployeeID)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.OrderDate)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.RequiredDate)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.ShippedDate)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.TotalAmount)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.TotalTax)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.VatTotal)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Freight)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.FinalPrice)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.ShipCountry)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.ShipVia)
                </th>
                <th class="text-nowrap">Functions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><button class="getOrderId bi bi-pencil-square" data-order-id="@item.OrderID"></button></td>
                    <td  class="cell-orderid" data-label="@Html.DisplayNameFor(model => model.OrderID)">
                        @Html.DisplayFor(_ => item.OrderID)
                    </td>
                    <td class="cell-customer" data-label="@Html.DisplayNameFor(model => model.CustomerID)">
                        @Html.DisplayFor(_ => item.Customer.CompanyName)
                    </td>
                    <td class="cell-employee" data-label="@Html.DisplayNameFor(model => model.EmployeeID)">
                        @Html.DisplayFor(_ => item.Employee.LastName)
                    </td>
                    <td class="cell-orderdate" data-label="@Html.DisplayNameFor(model => model.OrderDate)">
                        @Html.DisplayFor(_ => item.OrderDate)
                    </td>
                    <td class="cell-requireddate" data-label="@Html.DisplayNameFor(model => model.RequiredDate)">
                        @Html.DisplayFor(_ => item.RequiredDate)
                    </td>
                    <td class="cell-shippeddate" data-label="@Html.DisplayNameFor(model => model.ShippedDate)">
                        @Html.DisplayFor(_ => item.ShippedDate)
                    </td>
                    <td class="cell-totalamount" data-label="@Html.DisplayNameFor(model => model.TotalAmount)">
                        @Html.DisplayFor(_ => item.TotalAmount)
                    </td>
                    <td class="cell-totaltax" data-label="@Html.DisplayNameFor(model => model.TotalTax)">
                        @Html.DisplayFor(_ => item.TotalTax)
                    </td>
                    <td class="cell-vattotal" data-label="@Html.DisplayNameFor(model => model.VatTotal)">
                        @Html.DisplayFor(_ => item.VatTotal)
                    </td>
                    <td class="cell-freight" data-label="@Html.DisplayNameFor(model => model.Freight)">
                        @Html.DisplayFor(_ => item.Freight)
                    </td>
                    <td class="cell-finalprice" data-label="@Html.DisplayNameFor(model => model.FinalPrice)">
                        @Html.DisplayFor(_ => item.FinalPrice)
                    </td>
                    <td class="cell-shipcountry" data-label="@Html.DisplayNameFor(model => model.ShipCountry)">
                        @Html.DisplayFor(_ => item.ShipCountry)
                    </td>
                    <td class="cell-shipvia" data-label="@Html.DisplayNameFor(model => model.ShipVia)">
                        @Html.DisplayFor(_ => item.Shipper.CompanyName)
                    </td>
                    <td class="cell-actions">
                        <a class="btn btn-sm btn-warning me-1" href="@Url.Action("Edit", new { id = item.OrderID, returnUrl = returnUrl })">
                            <i class="bi bi-pencil-square me-1" aria-hidden="true"></i>
                            <span>Edit</span>
                        </a>
                        <a class="btn btn-sm btn-info me-1" href="@Url.Action("Details", new { id = item.OrderID, returnUrl = returnUrl })">
                            <i class="bi bi-info-square me-1" aria-hidden="true"></i>
                            <span>Details</span>
                        </a>
                        @using (Html.BeginForm("MoveToRecycleBin", "Orders",
                            new { id = item.OrderID, returnUrl = returnUrl }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash-fill me-1" aria-hidden="true"></i>
                                <span>Recycle</span>
                            </button>
                        }
                    </td>
                </tr>
            }
            <tr id="no-results-orders" style="display: none; border: none">
                <td colspan="2" style="text-align: center; padding: 40px; padding-left: 40px !important; color: #666; border: 1px solid; border-radius: 8px;">
                    No search results.
                </td>
            </tr>
        </tbody>
    </table>
</div>

@section scripts{
    <script>
        $(function () {
            $(".getOrderId").click(function () {
                const orderId = $(this).data("order-id");
                const url = "/Orders/_ModalEdit/" + orderId;
                $.get(url)
                    .done(function (data) {
                        const host = $("#orderEdit");
                        host.empty();
                        host.html(data);

                        const modalEl = document.getElementById("editOrderModal");
                        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                        modal.show();
                    })
                    .fail(function (xhr) {
                        $("#orderEdit").html("<div class='alert alert-danger'>Error loading order details: " + xhr.statusText + "</div>");
                    });
            });
        });
    </script>
}