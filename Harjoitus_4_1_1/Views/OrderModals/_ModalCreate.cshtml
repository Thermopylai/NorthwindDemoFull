
@using Harjoitus_4_1_1.Models
@model Order

<div class="modal fade" id="createOrderModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title">Create New Order</h2>
            </div>
            <div class="modal-body">
                @using (Html.BeginForm("_ModalCreate", "OrderModals", FormMethod.Post, new { id = "createForm" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.CustomerID, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.DropDownListFor(model => model.CustomerID, (SelectList)ViewBag.CustomerID, "-- Select customer --", new { @class = "form-control" })
                            @Html.ValidationMessageFor(model => model.CustomerID, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <script>
                        (() => {
                            const modal = document.getElementById("createOrderModal");
                            if (!modal) return;

                            const customerDropdown = modal.querySelector("#CustomerID");
                            if (!customerDropdown) return;
                            if (customerDropdown.dataset.prefillBound === "true") return;
                            customerDropdown.dataset.prefillBound = "true";

                            const fields = {
                                shipName: modal.querySelector("#ShipName"),
                                shipAddress: modal.querySelector("#ShipAddress"),
                                shipCity: modal.querySelector("#ShipCity"),
                                shipRegion: modal.querySelector("#ShipRegion"),
                                shipPostalCode: modal.querySelector("#ShipPostalCode"),
                                shipCountry: modal.querySelector("#ShipCountry")
                            };

                            const clearFields = () => {
                                Object.values(fields).forEach(el => { if (el) el.value = ""; });
                            };

                            customerDropdown.addEventListener("change", async () => {
                                const selectedCustomer = customerDropdown.value;

                                if (!selectedCustomer) {
                                    clearFields();
                                    return;
                                }

                                const url = '@Url.Action("GetCustomerForOrder", "Customers")' +
                                            '?id=' + encodeURIComponent(selectedCustomer);

                                try {
                                    const response = await fetch(url, { method: "GET" });

                                    if (!response.ok) {
                                        clearFields();
                                        return;
                                    }

                                    const customerDetails = await response.json();

                                    fields.shipName.value = customerDetails.CompanyName || "";
                                    fields.shipAddress.value = customerDetails.Address || "";
                                    fields.shipCity.value = customerDetails.City || "";
                                    fields.shipRegion.value = customerDetails.Region || "";
                                    fields.shipPostalCode.value = customerDetails.PostalCode || "";
                                    fields.shipCountry.value = customerDetails.Country || "";
                                } catch (err) {
                                    clearFields();
                                }
                            });
                        })();
                        (() => {
                            const modalEl = document.getElementById("createOrderModal");
                            if (!modalEl) return;

                            const form = modalEl.querySelector("#createForm");
                            if (!form) return;

                            // Avoid double-binding when modal HTML is replaced
                            if (form.dataset.ajaxBound === "true") return;
                            form.dataset.ajaxBound = "true";

                            $(form).on("submit", function (e) {
                                e.preventDefault();

                                $.ajax({
                                    url: form.action,
                                    type: "POST",
                                    data: $(form).serialize(),
                                    dataType: "json" // expect JSON on success
                                })
                                    .done(function (json) {
                                        if (json && json.ok) {
                                            bootstrap.Modal.getOrCreateInstance(modalEl).hide();
                                            window.location.reload();
                                        } else {
                                            alert((json && json.message) ? json.message : "Create failed.");
                                        }
                                    })
                                    .fail(function (xhr) {
                                        if (xhr.status === 401) {
                                            try { alert(JSON.parse(xhr.responseText).message || "Not authorized."); }
                                            catch { alert("Not authorized."); }
                                            return;
                                        }
                                        // Validation failure: server returned the partial view HTML
                                        const host = $("#orderCreate");
                                        host.empty();
                                        host.html(xhr.responseText);

                                        const newModalEl = document.getElementById("createOrderModal");
                                        const modal = bootstrap.Modal.getOrCreateInstance(newModalEl);
                                        modal.show();
                                    });
                            });
                        })();
                    </script>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.EmployeeID, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.DropDownListFor(model => model.EmployeeID, (SelectList)ViewBag.EmployeeID, "-- Select employee --", new { @class = "form-control" })
                            @Html.ValidationMessageFor(model => model.EmployeeID, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.OrderDate, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.OrderDate, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.OrderDate, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.RequiredDate, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
