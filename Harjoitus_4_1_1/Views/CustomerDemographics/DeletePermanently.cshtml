@using Harjoitus_4_1_1.Models
@model CustomerDemographic

@{
    ViewBag.Title = "Delete Customer Demographic Permanently";
}

<h2>@ViewBag.Title</h2>
<h5>Are you sure you want to delete this permanently?</h5>
<h6>@Html.ValidationSummary(true, "", new { @class = "text-danger" })</h6>
<hr />

<div class="mt-3">
    <dl class="row">

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.CustomerDesc)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.CustomerDesc)
        </dd>

    </dl>

    @using (Html.BeginForm("DeletePermanently", "CustomerDemographics",
        new { id = Model.CustomerTypeID.Trim(), returnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <div class="mt-3 offset-md-2 col-md-10">
            <button type="submit" class="btn btn-danger me-1">
                <i class="bi bi-trash me-1" aria-hidden="true"></i>
                <span>Delete</span>
            </button>
            <a href="@ViewBag.ReturnUrl" class="btn btn-secondary">
                <i class="bi bi-skip-backward me-1" aria-hidden="true"></i>
                <span>Back</span>
            </a>
        </div>
    }
</div>
