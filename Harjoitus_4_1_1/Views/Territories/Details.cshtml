@using Harjoitus_4_1_1.ViewModels
@model TerritoriesViewModel

@{
    ViewBag.Title = "Territory Details";
    var returnUrl = Model.ReturnUrl ?? Url.Action("Index");
    var returnToThisUrl = Request.Url.PathAndQuery;
}

<h2>@ViewBag.Title</h2>
<h5>Territory: <em>@Html.DisplayFor(model => model.Territory.TerritoryID)</em></h5>
<hr />

<div>
    <dl class="row">

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Territory.TerritoryDescription)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Territory.TerritoryDescription)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Territory.RegionID)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Territory.Region.RegionDescription)
        </dd>

    </dl>
</div>

<div class="mt-3 offset-md-2 col-md-10">
    <a class="btn btn-warning me-1" href="@Url.Action("Edit", new { id = Model.Territory.TerritoryID.Trim(), returnUrl = returnToThisUrl })">
        <i class="bi bi-pencil-square me-1" aria-hidden="true"></i>
        <span>Edit</span>
    </a>
    <a href="@returnUrl" class="btn btn-secondary">
        <i class="bi bi-skip-backward me-1" aria-hidden="true"></i>    
        <span>Back</span>
    </a>
</div>

<div>
    <hr />

    <h5>Employees associated with this territory: @Model.EmployeesCount</h5>

    @if (Model.EmployeesCount == 0)
    {
        <p>No items found.</p>
    }
    else
    {
        <div class="table-search-container">
            <input type="text"
                   id="search-employees"
                   onkeyup="filterTable('search-employees', 'employees-table')"
                   placeholder="Search..."
                   class="form-control mb-2">
        </div>

        <div class="table-wrapper">
            <table class="table table-striped table-bordered table-fixed" id="employees-table">
                <colgroup>
                    <col style="width: 50px;" />   @* EmployeeID *@
                    <col style="width: 60px;" />   @* TitleOfCourtesy *@
                    <col style="width: 100px;" />  @* LastName *@
                    <col style="width: 100px;" />  @* FirstName *@
                    <col style="width: 180px;" />  @* Title *@
                    <col style="width: 100px;" />  @* ReportsTo *@
                    <col style="width: 300px;" />  @* Functions *@
                </colgroup>
                <thead class="table-dark">
                    <tr>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1"></i>@Html.DisplayNameFor(model => model.Employees[0].EmployeeID)
                        </th>
                        <th class="sortable text-nowrap" title="@Html.DisplayNameFor(model => model.Employees[0].TitleOfCourtesy)">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Employees[0].TitleOfCourtesy)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Employees[0].LastName)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Employees[0].FirstName)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Employees[0].Title)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Employees[0].ReportsTo)
                        </th>
                        <th class="text-nowrap">
                            Functions
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Employees)
                    {
                        <tr>
                            <td data-label="@Html.DisplayNameFor(model => model.Employees[0].EmployeeID)">
                                @Html.DisplayFor(_ => item.EmployeeID)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Employees[0].TitleOfCourtesy)">
                                @Html.DisplayFor(_ => item.TitleOfCourtesy)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Employees[0].LastName)">
                                @Html.DisplayFor(_ => item.LastName)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Employees[0].FirstName)">
                                @Html.DisplayFor(_ => item.FirstName)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Employees[0].Title)">
                                @Html.DisplayFor(_ => item.Title)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.Employees[0].ReportsTo)">
                                @Html.DisplayFor(_ => item.Employee1.LastName)
                            </td>
                            <td class="cell-actions">
                                <a class="btn btn-sm btn-warning me-1" href="@Url.Action("Edit", "Employees", new { id = item.EmployeeID, returnUrl = returnToThisUrl })">
                                    <i class="bi bi-pencil-square me-1" aria-hidden="true"></i>
                                    <span>Edit</span>
                                </a>
                                <a class="btn btn-sm btn-info me-1" href="@Url.Action("Details", "Employees", new { id = item.EmployeeID, returnUrl = returnToThisUrl })">
                                    <i class="bi bi-info-square me-1" aria-hidden="true"></i>
                                    <span>Details</span>
                                </a>
                                @using (Html.BeginForm("MoveToRecycleBin", "Employees",
                                    new { id = item.EmployeeID, returnUrl = returnToThisUrl }, FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash-fill me-1" aria-hidden="true"></i>
                                        <span>Recycle</span>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                    <tr id="no-results-employees" style="display: none; border: none">
                        <td colspan="2" style="text-align: center; padding: 40px; padding-left: 40px !important; color: #666; border: 1px solid; border-radius: 8px;">
                            No search results.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>
