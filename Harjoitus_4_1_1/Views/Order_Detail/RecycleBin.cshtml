@using Harjoitus_4_1_1.Models
@model IEnumerable<Order_Detail>

@{
    ViewBag.Title = "Items in Orders - Recycle Bin";
    var returnUrl = (string)ViewBag.ReturnUrl ?? Request.Url.PathAndQuery;
}

<h2>@ViewBag.Title</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="validation-summary-errors">
        @TempData["ErrorMessage"]
    </div>
}

<hr />

<div class="d-flex flex-wrap align-items-center gap-2 mb-2">
    <a class="btn btn-secondary me-1" href="@Url.Action("Index", new { returnUrl = returnUrl })">
        <i class="bi bi-skip-backward me-1" aria-hidden="true"></i>
        <span>Back</span>
    </a>
    <input type="text"
           id="search-orderdetails"
           onkeyup="filterTable('search-orderdetails', 'orderdetails-table')"
           placeholder="Search..."
           class="form-control">
</div>

<div class="table-wrapper">
    <table class="table table-striped table-bordered table-fixed" id="orderdetails">
        <colgroup>
            <col style="width: 100px;" />  @* OrderID *@
            <col style="width: 260px;" />  @* Customer *@
            <col style="width: 280px;" />  @* ProductName *@
            <col style="width: 100px;" />  @* UnitPrice *@
            <col style="width: 100px;" />  @* Quantity *@
            <col style="width: 100px;" />  @* Discount *@
            <col style="width: 100px;" />  @* TotalPrice *@
            <col style="width: 100px;" />  @* TaxAmount *@
            <col style="width: 100px;" />  @* VatPrice *@
            <col style="width: 300px;" />  @* Functions *@
        </colgroup>
        <thead class="table-dark">
            <tr>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1"></i>@Html.DisplayNameFor(model => model.OrderID)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Order.Customer.CompanyName)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Product.ProductName)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.UnitPrice)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Quantity)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Discount)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.TotalPrice)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.TaxAmount)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.VatPrice)
                </th>
                <th class="text-nowrap">
                    Functions
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td data-label="@Html.DisplayNameFor(model => model.OrderID)">
                        @Html.DisplayFor(_ => item.OrderID)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.Order.Customer.CompanyName)">
                        @Html.DisplayFor(_ => item.Order.Customer.CompanyName)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.Product.ProductName)">
                        @Html.DisplayFor(_ => item.Product.ProductName)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.UnitPrice)">
                        @Html.DisplayFor(_ => item.UnitPrice)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.Quantity)">
                        @Html.DisplayFor(_ => item.Quantity)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.Discount)">
                        @Html.DisplayFor(_ => item.Discount)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.TotalPrice)">
                        @Html.DisplayFor(_ => item.TotalPrice)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.TaxAmount)">
                        @Html.DisplayFor(_ => item.TaxAmount)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.VatPrice)">
                        @Html.DisplayFor(_ => item.VatPrice)
                    </td>
                    <td class="cell-actions">
                        @using (Html.BeginForm("RestoreFromRecycleBin", "Order_Detail",
                            new { orderId = item.OrderID, productId = item.ProductID, returnUrl = returnUrl }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-success me-1">
                                <i class="bi bi-recycle me-1" aria-hidden="true"></i>
                                <span>Restore</span>
                            </button>
                        }
                        <a class="btn btn-sm btn-info me-1" href="@Url.Action("Details", new { orderId = item.OrderID, productId = item.ProductID, returnUrl = returnUrl })">
                            <i class="bi bi-info-square me-1" aria-hidden="true"></i>
                            <span>Details</span>
                        </a>
                        <a class="btn btn-sm btn-danger" href="@Url.Action("DeletePermanently", new { orderId = item.OrderID, productId = item.ProductID, returnUrl = returnUrl })">
                            <i class="bi bi-trash me-1" aria-hidden="true"></i>
                            <span>Delete</span>
                        </a>                           
                    </td>
                </tr>
            }
            <tr id="no-results-orderdetails" style="display: none; border: none">
                <td colspan="2" style="text-align: center; padding: 40px; padding-left: 40px !important; color: #666; border: 1px solid; border-radius: 8px;">
                    No search results.
                </td>
            </tr>
        </tbody>
    </table>
</div>
