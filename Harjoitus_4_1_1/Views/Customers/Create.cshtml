@using Harjoitus_4_1_1.Models
@model Customer

@{
    ViewBag.Title = "Create New Customer";
}

<h2>@ViewBag.Title</h2>
<hr />

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.Hidden("returnUrl", (string)ViewBag.ReturnUrl)
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="mb-3 row">
        <section class="col-md-4">
            <div class="mb-3">
                @Html.LabelFor(model => model.CustomerID, htmlAttributes: new { @class = "form-label fw-bold required" })
                @Html.EditorFor(model => model.CustomerID, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.CustomerID, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(model => model.CompanyName, htmlAttributes: new { @class = "form-label fw-bold required" })
                @Html.EditorFor(model => model.CompanyName, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.CompanyName, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(model => model.ContactName, htmlAttributes: new { @class = "form-label fw-bold required" })
                @Html.EditorFor(model => model.ContactName, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.ContactName, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(model => model.ContactTitle, htmlAttributes: new { @class = "form-label fw-bold required" })
                @Html.EditorFor(model => model.ContactTitle, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.ContactTitle, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(model => model.Address, htmlAttributes: new { @class = "form-label fw-bold required" })
                @Html.EditorFor(model => model.Address, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.Address, "", new { @class = "text-danger" })
            </div>
        </section>
        <section class="col-md-4">
            <div class="mb-3">
                @Html.LabelFor(model => model.PostalCode, htmlAttributes: new { @class = "form-label fw-bold required" })
                @Html.EditorFor(model => model.PostalCode, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.PostalCode, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(model => model.City, htmlAttributes: new { @class = "form-label fw-bold required" })
                @Html.EditorFor(model => model.City, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.City, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(model => model.Country, htmlAttributes: new { @class = "form-label fw-bold required" })
                @Html.EditorFor(model => model.Country, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.Country, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(model => model.Phone, htmlAttributes: new { @class = "form-label fw-bold required" })
                @Html.EditorFor(model => model.Phone, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.Phone, "", new { @class = "text-danger" })
            </div>
        </section>
        <section class="col-md-4">
            <div class="mb-3">
                @Html.LabelFor(model => model.Fax, htmlAttributes: new { @class = "form-label fw-bold" })
                @Html.EditorFor(model => model.Fax, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.Fax, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(model => model.Region, htmlAttributes: new { @class = "form-label fw-bold" })
                @Html.EditorFor(model => model.Region, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.Region, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(model => model.CustomerDemographics, htmlAttributes: new { @class = "form-label fw-bold" })
                @Html.ListBox("CustomerTypeID", (MultiSelectList)ViewBag.CustomerTypeIDs, new { @class = "form-control" })
                @Html.ValidationMessage("CustomerTypeID", "", new { @class = "text-danger" })
            </div>
        </section>
        <section class="my-3">
            <button type="submit" class="btn btn-primary me-1">
                <i class="bi bi-file-earmark-plus me-1" aria-hidden="true"></i>
                <span>Create</span>
            </button>
            <a href="@ViewBag.ReturnUrl" class="btn btn-secondary">
                <i class="bi bi-skip-backward me-1" aria-hidden="true"></i>
                <span>Back</span>
            </a>
        </section>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
