@using Harjoitus_4_1_1.Models
@model Order

@{
    ViewBag.Title = "Create New Order";
}

<h2>@ViewBag.Title</h2>
<hr />

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.Hidden("returnUrl", (string)ViewBag.ReturnUrl)
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="mb-3 row">
        @Html.LabelFor(model => model.CustomerID, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.DropDownListFor(model => model.CustomerID, (SelectList)ViewBag.CustomerID, "-- Select customer --", new { @class = "form-control", id = "customerId" })
            @Html.ValidationMessageFor(model => model.CustomerID, "", new { @class = "text-danger" })
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const customerDropdown = document.getElementById("customerId");
            if (!customerDropdown) return;

            const fields = {
                shipName: document.getElementById("shipName"),
                shipAddress: document.getElementById("shipAddress"),
                shipCity: document.getElementById("shipCity"),
                shipRegion: document.getElementById("shipRegion"),
                shipPostalCode: document.getElementById("shipPostalCode"),
                shipCountry: document.getElementById("shipCountry")
            };

            const clearFields = () => {
                Object.values(fields).forEach(el => { if (el) el.value = ""; });
            };

            customerDropdown.addEventListener("change", async () => {
                const selectedCustomer = customerDropdown.value;

                if (!selectedCustomer) {
                    clearFields();
                    return;
                }

                const url = '@Url.Action("GetCustomerForOrder", "Customers")' +
                            '?id=' + encodeURIComponent(selectedCustomer);

                try {
                    const response = await fetch(url, { method: "GET" });

                    if (!response.ok) {
                        clearFields();
                        console.log("Failed to load customer details. Status:", response.status);
                        return;
                    }

                    const customerDetails = await response.json();

                    fields.shipName.value = customerDetails.CompanyName || "";
                    fields.shipAddress.value = customerDetails.Address || "";
                    fields.shipCity.value = customerDetails.City || "";
                    fields.shipRegion.value = customerDetails.Region || "";
                    fields.shipPostalCode.value = customerDetails.PostalCode || "";
                    fields.shipCountry.value = customerDetails.Country || "";
                } catch (err) {
                    clearFields();
                    console.log("Fetch error:", err);
                }
            });
        });
    </script>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.EmployeeID, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.DropDownListFor(model => model.EmployeeID, (SelectList)ViewBag.EmployeeID, "-- Select employee --", new { @class = "form-control" })
            @Html.ValidationMessageFor(model => model.EmployeeID, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.OrderDate, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.OrderDate, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.OrderDate, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.RequiredDate, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.RequiredDate, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.RequiredDate, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.ShippedDate, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.ShippedDate, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.ShippedDate, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
        @Html.LabelFor(model => model.ShipVia, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.DropDownListFor(model => model.ShipVia, (SelectList)ViewBag.ShipVia, "-- Select shipper --", new { @class = "form-control" })
            @Html.ValidationMessageFor(model => model.ShipVia, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mb-3 row">
