@using Harjoitus_4_1_1.ViewModels
@model OrdersViewModel

@{
    ViewBag.Title = "Delete Order Permanently";
    var returnUrl = Request.Url.PathAndQuery;
}

<h2>@ViewBag.Title</h2>
<h4>Are you sure you want to delete this order and its items permanently?</h4>
<h5>Order: <em>@Html.DisplayFor(model => model.Order.OrderID)</em></h5>
<h6>@Html.ValidationSummary(true, "", new { @class = "text-danger" })</h6>
<hr />

<div class="mt-3">
    <dl class="row">

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.CustomerID)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.Customer.CompanyName)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.EmployeeID)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.Employee.LastName)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.OrderDate)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.OrderDate)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.RequiredDate)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.RequiredDate)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.ShippedDate)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.ShippedDate)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.TotalAmount)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.TotalAmount)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.TotalTax)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.TotalTax)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.VatTotal)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.VatTotal)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.Freight)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.Freight)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.FinalPrice)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.FinalPrice)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.ShipName)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.ShipName)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.ShipAddress)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.ShipAddress)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.ShipCity)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.ShipCity)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.ShipRegion)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.ShipRegion)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.ShipPostalCode)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.ShipPostalCode)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.ShipCountry)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.ShipCountry)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.Order.ShipVia)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.Order.Shipper.CompanyName)
        </dd>

    </dl>

    @using (Html.BeginForm("DeletePermanently", "Orders", new { id = Model.Order.OrderID, returnUrl = Model.ReturnUrl }, FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <div class="mt-3 offset-md-2 col-md-10">
            <button type="submit" class="btn btn-danger me-1">
                <i class="bi bi-trash me-1" aria-hidden="true"></i>
                <span>Delete</span>
            </button>
            <a href="@Model.ReturnUrl" class="btn btn-secondary">
                <i class="bi bi-skip-backward me-1" aria-hidden="true"></i>
                <span>Back</span>
            </a>
        </div>
    }
</div>

<div>
    <hr />

    <h5>Items in this order: @Model.OrderDetailsCount</h5>

    @if (Model.OrderDetailsCount == 0)
    {
        <p>No items found.</p>
    }
    else
    {
        <h6><strong>Warning!</strong> These items will be deleted permanently.</h6>

        <div class="table-search-container">
            <input type="text"
                   id="search-orderdetails"
                   onkeyup="filterTable('search-orderdetails', 'orderdetails-table')"
                   placeholder="Search..."
                   class="form-control mb-2">
        </div>

        <div class="table-wrapper">
            <table class="table table-striped table-bordered table-fixed" id="orderdetails-table">
                <colgroup>
                    <col style="width: 260px;" />  @* ProductName *@
                    <col style="width: 100px;" />  @* UnitPrice *@
                    <col style="width: 100px;" />  @* Quantity *@
                    <col style="width: 100px;" />  @* Discount *@
                    <col style="width: 100px;" />  @* TotalPrice *@
                    <col style="width: 100px;" />  @* TaxAmount *@
                    <col style="width: 100px;" />  @* VatPrice *@
                    <col style="width: 80px;" />   @* IsDeleted *@
                    <col style="width: 300px;" />  @* Functions *@
                </colgroup>
                <thead class="table-dark">
                    <tr>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1"></i>@Html.DisplayNameFor(model => model.OrderDetails[0].Product.ProductName)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.OrderDetails[0].UnitPrice)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.OrderDetails[0].Quantity)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.OrderDetails[0].Discount)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.OrderDetails[0].TotalPrice)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.OrderDetails[0].TaxAmount)
                        </th>
                        <th class="sortable text-nowrap">
                            <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.OrderDetails[0].VatPrice)
                        </th>
                        <th class="text-nowrap">
                            @Html.DisplayNameFor(model => model.OrderDetails[0].IsDeleted)
                        </th>
                        <th class="text-nowrap">
                            Functions
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderDetails)
                    {
                        <tr>
                            <td data-label="@Html.DisplayNameFor(model => model.OrderDetails[0].Product.ProductName)">
                                @Html.DisplayFor(_ => item.Product.ProductName)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.OrderDetails[0].UnitPrice)">
                                @Html.DisplayFor(_ => item.UnitPrice)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.OrderDetails[0].Quantity)">
                                @Html.DisplayFor(_ => item.Quantity)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.OrderDetails[0].Discount)">
                                @Html.DisplayFor(_ => item.Discount)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.OrderDetails[0].TotalPrice)">
                                @Html.DisplayFor(_ => item.TotalPrice)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.OrderDetails[0].TaxAmount)">
                                @Html.DisplayFor(_ => item.TaxAmount)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.OrderDetails[0].VatPrice)">
                                @Html.DisplayFor(_ => item.VatPrice)
                            </td>
                            <td data-label="@Html.DisplayNameFor(model => model.OrderDetails[0].IsDeleted)">
                                @Html.DisplayFor(_ => item.IsDeleted)
                            </td>
                            <td class="cell-actions">
                                <a class="btn btn-sm btn-warning me-1" href="@Url.Action("Edit", "Order_Details", new { orderId = item.OrderID, productId = item.ProductID, returnUrl = returnUrl })">
                                    <i class="bi bi-pencil-square me-1" aria-hidden="true"></i>
                                    <span>Edit</span>
                                </a>
                                <a class="btn btn-sm btn-info me-1" href="@Url.Action("Details", "Order_Details", new { orderId = item.OrderID, productId = item.ProductID, returnUrl = returnUrl })">
                                    <i class="bi bi-info-square me-1" aria-hidden="true"></i>
                                    <span>Details</span>
                                </a>
                                <a class="btn btn-sm btn-danger" href="@Url.Action("DeletePermanently", "Order_Detail", new { orderId = item.OrderID, productId = item.ProductID, returnUrl = returnUrl })">
                                    <i class="bi bi-trash me-1" aria-hidden="true"></i>
                                    <span>Delete</span>
                                </a>
                            </td>
                        </tr>
                    }
                    <tr id="no-results-orderdetails" style="display: none; border: none">
                        <td colspan="2" style="text-align: center; padding: 40px; padding-left: 40px !important; color: #666; border: 1px solid; border-radius: 8px;">
                            No search results.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>
