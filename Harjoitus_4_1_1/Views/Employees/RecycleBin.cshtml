@using Harjoitus_4_1_1.Models
@model IEnumerable<Employee>

@{
    ViewBag.Title = "Employees - Recycle Bin";
    var returnUrl = (string)ViewBag.ReturnUrl ?? Request.Url.PathAndQuery;
}

<h2>@ViewBag.Title</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="validation-summary-errors">
        @TempData["ErrorMessage"]
    </div>
}

<hr />

<div class="d-flex flex-wrap align-items-center gap-2 mb-2">
    <a class="btn btn-secondary me-1" href="@Url.Action("Index", new { returnUrl = returnUrl })">
        <i class="bi bi-skip-backward me-1" aria-hidden="true"></i>
        <span>Back</span>
    </a>
    <input type="text"
           id="search-employees"
           onkeyup="filterTable('search-employees', 'employees-table')"
           placeholder="Search..."
           class="form-control">
</div>

<div class="table-wrapper">
    <table class="table table-striped table-bordered table-fixed" id="employees-table">
        <colgroup>
            <col style="width: 60px;" />   @* EmployeeID *@
            <col style="width: 100px;" />  @* FirstName *@
            <col style="width: 100px;" />  @* LastName *@
            <col style="width: 100px;" />  @* TitleOfCourtesy *@
            <col style="width: 180px;" />  @* Title *@
            <col style="width: 100px;" />  @* BirthDate *@
            <col style="width: 100px;" />  @* HireDate *@
            <col style="width: 100px;" />  @* ReportsTo *@
            <col style="width: 200px;" />  @* Address *@
            <col style="width: 80px;" />   @* PostalCode *@
            <col style="width: 90px;" />   @* City *@
            <col style="width: 90px;" />   @* Country *@
            <col style="width: 130px;" />  @* HomePhone *@
            <col style="width: 100px;" />  @* Extension *@
            <col style="width: 80px;" />   @* Region *@
            <col style="width: 300px;" />  @* Functions *@
        </colgroup>
        <thead class="table-dark">
            <tr>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1"></i>@Html.DisplayNameFor(model => model.EmployeeID)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.FirstName)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.LastName)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.TitleOfCourtesy)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Title)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.BirthDate)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.HireDate)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.ReportsTo)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Address)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.PostalCode)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.City)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Country)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.HomePhone)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Extension)
                </th>
                <th class="sortable text-nowrap">
                    <i class="bi-arrow-down me-1 d-none"></i>@Html.DisplayNameFor(model => model.Region)
                </th>
                <th class="text-nowrap">
                    Functions
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td data-label="@Html.DisplayNameFor(model => model.EmployeeID)">
                        @Html.DisplayFor(_ => item.EmployeeID)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.FirstName)">
                        @Html.DisplayFor(_ => item.FirstName)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.LastName)">
                        @Html.DisplayFor(_ => item.LastName)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.TitleOfCourtesy)">
                        @Html.DisplayFor(_ => item.TitleOfCourtesy)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.Title)">
                        @Html.DisplayFor(_ => item.Title)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.BirthDate)">
                        @Html.DisplayFor(_ => item.BirthDate)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.HireDate)">
                        @Html.DisplayFor(_ => item.HireDate)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.ReportsTo)">
                        @Html.DisplayFor(_ => item.Employee1.LastName)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.Address)">
                        @Html.DisplayFor(_ => item.Address)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.PostalCode)">
                        @Html.DisplayFor(_ => item.PostalCode)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.City)">
                        @Html.DisplayFor(_ => item.City)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.Country)">
                        @Html.DisplayFor(_ => item.Country)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.HomePhone)">
                        @Html.DisplayFor(_ => item.HomePhone)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.Extension)">
                        @Html.DisplayFor(_ => item.Extension)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.Region)">
                        @Html.DisplayFor(_ => item.Region)
                    </td>
                    <td class="cell-actions">
                        @using (Html.BeginForm("RestoreFromRecycleBin", "Employees",
                            new { id = item.EmployeeID, returnUrl = returnUrl }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-success me-1">
                                <i class="bi bi-recycle me-1" aria-hidden="true"></i>
                                <span>Restore</span>
                            </button>
                        }
                        <a class="btn btn-sm btn-info me-1" href="@Url.Action("Details", new { id = item.EmployeeID, returnUrl = returnUrl })">
                            <i class="bi bi-info-square me-1" aria-hidden="true"></i>
                            <span>Details</span>
                        </a>
                        <a class="btn btn-sm btn-danger" href="@Url.Action("DeletePermanently", new { id = item.EmployeeID, returnUrl = returnUrl })">
                            <i class="bi bi-trash me-1" aria-hidden="true"></i>
                            <span>Delete</span>
                        </a>
                    </td>
                </tr>
            }
            <tr id="no-results-employees" style="display: none; border: none">
                <td colspan="2" style="text-align: center; padding: 40px; padding-left: 40px !important; color: #666; border: 1px solid; border-radius: 8px;">
                    No search results.
                </td>
            </tr>
        </tbody>
    </table>
</div>
