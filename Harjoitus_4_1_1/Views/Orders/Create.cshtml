    <div class="mb-3 row">
        @Html.LabelFor(model => model.ShipCountry, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.ShipCountry, new { htmlAttributes = new { @class = "form-control", id = "shipCountry" } })
            @Html.ValidationMessageFor(model => model.ShipCountry, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="row">
        <div class="offset-md-2 col-md-10">
            <button type="submit" class="btn btn-primary me-1">
                <i class="bi bi-file-earmark-plus me-1" aria-hidden="true"></i>
                <span>Create</span>
            </button>
            <a href="@ViewBag.ReturnUrl" class="btn btn-secondary">
                <i class="bi bi-skip-backward me-1" aria-hidden="true"></i>
                <span>Back</span>
            </a>
        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
