@using Harjoitus_4_1_1.Models
@model CustomerDemographic

@{
    ViewBag.Title = "Customer Demographic Details";
    var returnUrl = (string)ViewBag.ReturnUrl ?? Url.Action("Index");
    var returnToThisUrl = Request.Url.PathAndQuery;
}

<h2>@ViewBag.Title</h2>
<hr />

<div>
    <dl class="row">
        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.CustomerDesc)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.CustomerDesc)
        </dd>
    </dl>
</div>

<div class="mt-3 offset-md-2 col-md-10">
    <a class="btn btn-warning me-1" href="@Url.Action("Edit", new { id = Model.CustomerTypeID.Trim(), returnUrl = returnToThisUrl })">
        <i class="bi bi-pencil-square me-1" aria-hidden="true"></i>
        <span>Edit</span>
    </a>
    <a href="@returnUrl" class="btn btn-secondary">
        <i class="bi bi-skip-backward me-1" aria-hidden="true"></i>    
        <span>Back</span>
    </a>
</div>
