                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.ShipCity, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.ShipCity, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ShipCity, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.ShipRegion, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.ShipRegion, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ShipRegion, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.ShipPostalCode, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.ShipPostalCode, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ShipPostalCode, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.ShipCountry, htmlAttributes: new { @class = "form-label col-md-2 col-form-label text-md-end fw-bold required" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.ShipCountry, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ShipCountry, "", new { @class = "text-danger" })
                        </div>
                    </div>


                }
            </div>
            <div class="modal-footer">
                <div class="offset-md-2 col-md-10">
                    <button type="submit" form="createForm" class="btn btn-primary me-1">
                        <i class="bi bi-file-earmark-plus me-1" aria-hidden="true"></i>
                        <span>Create</span>
                    </button>
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x me-1" aria-hidden="true"></i>
                        <span>Cancel</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
