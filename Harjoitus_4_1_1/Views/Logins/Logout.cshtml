@using Harjoitus_4_1_1.Models
@model Login

@{
    ViewBag.Title = "Logout Current User";
}

<h2>@ViewBag.Title</h2>
<h4>Are you sure?</h4>
<hr />

<div class="mt-3">
    <dl class="row">

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.LoginID)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.LoginID)
        </dd>

        <dt class="col-md-2 text-md-end">
            @Html.DisplayNameFor(model => model.UserName)
        </dt>

        <dd class="col-md-10">
            @Html.DisplayFor(model => model.UserName)
        </dd>

    </dl>

    @using (Html.BeginForm("LogoutConfirmed", "Logins", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.Hidden("returnUrl", (string)ViewBag.ReturnUrl)

        <div class="row">
            <div class="offset-md-2 col-md-10">
                <button type="submit" class="btn btn-danger me-1">
                    <i class="bi bi-key me-1" aria-hidden="true"></i>
                    <span>Logout</span>
                </button>
                <a href="@ViewBag.ReturnUrl" class="btn btn-secondary">
                    <i class="bi bi-skip-backward me-1" aria-hidden="true"></i>
                    <span>Back</span>
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
